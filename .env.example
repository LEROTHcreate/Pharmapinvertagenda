# ─── Mode démo ───
# Si 1, l'app utilise une session admin factice (BDD non sollicitée).
# DOIT rester à 0 en production sinon bypass d'auth complet.
DEMO_MODE=0

# ─── Base de données ───
# Supabase PostgreSQL (ou tout autre PostgreSQL)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres"
# Direct (sans pooler) — pour migrations Prisma uniquement
DIRECT_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# ─── Supabase Auth ───
# Identité (email/mot de passe + sessions) gérée par Supabase Auth.
# À récupérer dans Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey...anon-public-key"
# Clé service_role : SECRET serveur (signup/reset admin). Ne JAMAIS exposer au client.
SUPABASE_SERVICE_ROLE_KEY="ey...service-role-key"

# URL de l'application (liens emails, redirections)
# En développement :
NEXTAUTH_URL="http://localhost:3000"
# En production : l'URL Netlify (ex: https://pharma-planning.netlify.app)

# ─── Mentions légales (éditeur du site) — LCEN art. 6 ───
# À REMPLIR avant ouverture commerciale. Tout champ vide s'affiche « à
# renseigner » sur /mentions-legales. Aucune donnée sensible : ce sont les
# infos publiques de l'entreprise éditrice. (Modifiables sans redéploiement.)
LEGAL_RAISON_SOCIALE=""            # ex. "THOREL INDUSTRIES"
LEGAL_FORME_JURIDIQUE=""           # ex. "SAS"
LEGAL_CAPITAL_SOCIAL=""            # ex. "1000"
LEGAL_ADRESSE_SIEGE=""             # ex. "12 rue de la Pharmacie, 75000 Paris"
LEGAL_SIRET=""                     # 14 chiffres
LEGAL_RCS=""                       # ex. "Paris B 123 456 789"
LEGAL_TVA_INTRA=""                 # ex. "FR12345678901"
LEGAL_TELEPHONE=""                 # ex. "07 69 46 24 46"
LEGAL_EMAIL=""                     # défaut : contact@pharmaplanning.fr
LEGAL_DIRECTEUR_PUBLICATION=""     # ex. "Nicolas Thorel"
LEGAL_QUALITE_DIRECTEUR=""         # ex. "Président"

# ─── Monitoring d'erreurs Sentry (optionnel) ───
# DSN du projet Sentry (Settings → Client Keys). Clé d'ingestion write-only,
# sans risque en public. Vide = monitoring désactivé (no-op, build identique).
NEXT_PUBLIC_SENTRY_DSN=""

# ─── Cron anti-pause BDD (optionnel mais recommandé) ───
# Sécurise /api/cron/keepalive : Vercel envoie "Authorization: Bearer <CRON_SECRET>".
# Génère avec : openssl rand -hex 32. Si absent, l'endpoint reste accessible (ping read-only).
CRON_SECRET=""

# ─── Emails transactionnels via Gmail SMTP (Nodemailer) ───
# Setup en 3 étapes :
#  1. Active la 2FA sur ton compte Google : https://myaccount.google.com/security
#  2. Génère un "Mot de passe d'application" (App Password) :
#     https://myaccount.google.com/apppasswords
#     → choisis "Mail" + "Autre (nom personnalisé)" → ex. "PharmaPlanning"
#     → Google te donne 16 caractères (sans espaces) — c'est ton GMAIL_APP_PASSWORD.
#  3. Renseigne les 2 vars ci-dessous (puis copie-les côté Netlify).
#
# Limite Gmail : 500 emails/jour (gratuit) / 2000/jour (Workspace).
GMAIL_USER="ton.email@gmail.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
# Affichage de l'expéditeur — par défaut "PharmaPlanning <GMAIL_USER>".
EMAIL_FROM="PharmaPlanning <ton.email@gmail.com>"

# ─── Assistant IA « Hygie » (Groq) ───
# Clé API Groq (inférence rapide, modèles open source). Crée-la sur
# https://console.groq.com → API Keys. SECRET serveur — jamais exposée au client.
# Vide = assistant désactivé (la bulle affiche un message d'indisponibilité).
GROQ_API_KEY=""

# ─── Comptes de seed (dev uniquement) ───
# Utilisés UNIQUEMENT par prisma/seed.ts et prisma/update-admin.ts.
# Ne pas hardcoder dans le code (Netlify secret scan refuse le déploiement).
SEED_ADMIN_PASSWORD="changeMe-admin"
SEED_EMPLOYEE_PASSWORD="changeMe-emp"

# ─── Web Push (notifications hors-app) ───
# Générer une paire avec :  npx web-push generate-vapid-keys
# La clé PUBLIQUE est exposée au client (préfixe NEXT_PUBLIC_). La PRIVÉE est
# un SECRET serveur. VAPID_SUBJECT = mailto: ou URL de contact.
# Sans ces variables, le push est simplement inactif (l'app fonctionne).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@pharmaplanning.fr"
