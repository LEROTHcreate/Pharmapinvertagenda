# ─── Mode démo ───
# Si 1, l'app utilise une session admin factice (BDD non sollicitée).
# DOIT rester à 0 en production sinon bypass d'auth complet.
DEMO_MODE=0

# ─── Base de données ───
# Supabase PostgreSQL (ou tout autre PostgreSQL)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres"
# Direct (sans pooler) — pour migrations Prisma uniquement
DIRECT_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# ─── NextAuth.js ───
# Secret pour signer les JWT — OBLIGATOIRE en prod
# Génère avec : openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-ici-genere-avec-openssl-rand-base64-32"
AUTH_SECRET="memes-valeur-que-NEXTAUTH_SECRET"

# URL de l'application
# En développement :
NEXTAUTH_URL="http://localhost:3000"
# En production : l'URL Netlify (ex: https://pharma-planning.netlify.app)

# ─── Emails transactionnels via Gmail SMTP (Nodemailer) ───
# Setup en 3 étapes :
#  1. Active la 2FA sur ton compte Google : https://myaccount.google.com/security
#  2. Génère un "Mot de passe d'application" (App Password) :
#     https://myaccount.google.com/apppasswords
#     → choisis "Mail" + "Autre (nom personnalisé)" → ex. "PharmaPlanning"
#     → Google te donne 16 caractères (sans espaces) — c'est ton GMAIL_APP_PASSWORD.
#  3. Renseigne les 2 vars ci-dessous (puis copie-les côté Netlify).
#
# Limite Gmail : 500 emails/jour (gratuit) / 2000/jour (Workspace).
GMAIL_USER="ton.email@gmail.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
# Affichage de l'expéditeur — par défaut "PharmaPlanning <GMAIL_USER>".
EMAIL_FROM="PharmaPlanning <ton.email@gmail.com>"

# ─── Comptes de seed (dev uniquement) ───
# Utilisés UNIQUEMENT par prisma/seed.ts et prisma/update-admin.ts.
# Ne pas hardcoder dans le code (Netlify secret scan refuse le déploiement).
SEED_ADMIN_PASSWORD="changeMe-admin"
SEED_EMPLOYEE_PASSWORD="changeMe-emp"
