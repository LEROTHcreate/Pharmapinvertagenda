// prisma/schema.prisma
// Schéma de données PharmaPlanning

generator client {
  provider      = "prisma-client-js"
  // engineType=library = client Prisma standard (lit DATABASE_URL en
  // postgresql://). Empêche Netlify d'auto-générer en mode Data Proxy
  // qui exigerait une URL prisma://.
  engineType    = "library"
  // Cibles binaires : native (dev local Windows/Mac) + RHEL OpenSSL 3
  // (runtime des Netlify Functions sur AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────

enum UserRole {
  // Rôles de PERMISSION (distincts du statut métier EmployeeStatus).
  // Du plus puissant au moins puissant. Cf. src/lib/permissions.ts.
  CREATEUR // Créateur de l'officine — tous pouvoirs, indéracinable, transférable
  ADMIN // Titulaire — tous pouvoirs sauf gérer le créateur
  MANAGEUR // Édite le planning + gabarits + équipe (pas absences/paie/réglages)
  COLLABORATEUR // Personnel — lecture + ses propres demandes
  EMPLOYEE // (legacy) — alias historique de COLLABORATEUR, normalisé en code
}

enum UserStatus {
  PENDING // Inscription en attente d'examen par un admin
  APPROVED // Compte validé — peut se connecter
  REJECTED // Demande refusée
}

enum EmployeeStatus {
  PHARMACIEN
  PREPARATEUR
  ETUDIANT
  LIVREUR
  BACK_OFFICE
  SECRETAIRE
  TITULAIRE
}

enum ScheduleType {
  TASK // Poste de travail (Comptoir, Commande, etc.)
  ABSENCE // Absence (Congé, Maladie, etc.)
}

enum TaskCode {
  COMPTOIR
  COMMANDE
  MISE_A_PRIX
  PARAPHARMACIE
  SECRETARIAT
  MAIL
  FORMATION
  HEURES_SUP
  LIVRAISON
  MISE_EN_RAYON // Mise en rayon (livreur)
  VERIFICATION_STOCKS // Vérification des stocks (livreur)
  ROBOT
  REMPLACEMENT
  ECHANGE
  REUNION_FOURNISSEUR
}

enum AbsenceCode {
  ABSENT
  CONGE
  MALADIE
  FORMATION_ABS
}

enum AbsenceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WeekType {
  S1
  S2
}

/// Type d'événement d'équipe (vie de l'officine) — chaque type a son ambiance
/// visuelle (couleur + animation) côté UI.
enum TeamEventType {
  REPAS // Repas d'équipe (mensuel, trimestriel, resto…)
  ANIMATION_LABO // Animation / journée d'un laboratoire
  REUNION_FOURNISSEUR // Réunion fournisseur / représentant
  ENTRETIEN // Entretien individuel collaborateur
  FORMATION // Formation / atelier interne
  AUTRE // Autre événement
}

enum MessageType {
  TEXT // Message texte simple
  SWAP_REQUEST // Message structuré portant une demande d'échange
  SYSTEM // Notification système dans la conv (ex: "X a rejoint")
}

enum SwapStatus {
  PENDING_TARGET // En attente d'accord du collègue sollicité
  REJECTED_TARGET // Refusé par le collègue
  PENDING_ADMIN // Accepté par le collègue, en attente validation admin
  APPROVED // Approuvé par l'admin → planning mis à jour
  REJECTED_ADMIN // Refusé par l'admin
  CANCELLED // Annulé par le demandeur
}

enum PayrollNoteStatus {
  PENDING // À comptabiliser — l'admin doit encore traiter
  ACCOUNTED // Comptabilisé par l'admin
}

/// Type de formation suivie par un collaborateur (catalogue + suivi DPC).
enum TrainingType {
  DPC // Développement Professionnel Continu (pharmacien, cycle triennal)
  OBLIGATOIRE // Formation obligatoire (hygiène, sécurité, gestes d'urgence…)
  INTERNE // Formation interne à l'officine
  EXTERNE // Formation externe / labo / organisme
  AUTRE // Autre
}

// ─── MODELS ──────────────────────────────────────────────────────

/// Pharmacie — entité multi-tenant racine
model Pharmacy {
  id       String  @id @default(cuid())
  name     String // Ex: "Pharmacie du Pin Vert"
  address  String?
  phone    String?
  siret    String? @unique
  minStaff Int     @default(4) // Seuil minimum d'effectif par créneau
  // Logo de l'officine — data URL base64 (uploadée depuis Paramètres,
  // max 200KB) ou chemin relatif (ex: "/logo.png" pour les pharmacies
  // seedées). Null = fallback sur le logo générique PharmaPlanning.
  logoUrl  String?

  // ─── Mémo du jour / consignes ──────────────────────────────────────
  // Note courte posée par un responsable, visible par toute l'équipe (bandeau
  // app-wide). Null/vide = pas de consigne affichée. `dailyNoticeAt` sert à
  // ré-afficher le bandeau à chacun quand la consigne change (clé de rappel).
  dailyNotice   String?
  dailyNoticeAt DateTime?

  // Horaires d'ouverture (JSON : 7 jours Lun→Dim, chaque jour = créneaux
  // {open,close}). Affichés sur l'écran vitrine public. Cf. src/lib/opening-hours.ts.
  openingHours String?

  // ─── Réglages Rémunération ─────────────────────────────────────────
  // Région de référence pour le benchmark marché (NATIONAL, IDF,
  // GRANDE_METROPOLE, PROVINCE, RURAL). Null = NATIONAL par défaut.
  payrollRegion          String?
  // Taux de cotisations paramétrables (override des défauts 0.22 / 0.42).
  // Null = on retombe sur DEFAULT_PAYROLL_RATES.
  payrollContribEmployee Float? // Cotisations salariales (ex: 0.22)
  payrollContribEmployer Float? // Cotisations patronales (ex: 0.42)
  // Budget annuel de masse salariale (coût employeur total, €). Sert au
  // prévisionnel Rémunération (projection au rythme du mois vs budget + alerte
  // de dérive). Null = pas de budget défini.
  payrollAnnualBudget    Float?

  // ─── Réglages Pharmacie de garde ───────────────────────────────────
  // Indemnités de garde (€) par type. Null = valeurs par défaut indicatives
  // (voir GARDE_RATES_PLACEHOLDER). Modifiables depuis la page /gardes.
  gardeRateNuit      Float? // Indemnité d'une garde de nuit
  gardeRateDimanche  Float? // Indemnité d'une garde de dimanche
  gardeRateJourFerie Float? // Indemnité d'une garde de jour férié

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  employees          Employee[]
  scheduleEntries    ScheduleEntry[]
  absenceRequests    AbsenceRequest[]
  weekTemplates      WeekTemplate[]
  conversations      Conversation[]
  swapRequests       ShiftSwapRequest[]
  payrollNotes       PayrollNote[]
  availabilityWishes AvailabilityWish[]
  monthlyRevenues    MonthlyRevenue[]
  gardes             Garde[]
  teamEvents         TeamEvent[]
  openShifts         OpenShift[]
  polls              Poll[]
  trainings          Training[]

  @@map("pharmacies")
}

/// Compte utilisateur (connexion)
model User {
  id             String     @id @default(cuid())
  email          String     @unique
  // Identité gérée par Supabase Auth. `hashedPassword` reste un miroir bcrypt
  // (maintenu au signup/reset/change) pour la vérification de l'ancien mot de
  // passe sans round-trip, mais la source de vérité du login est Supabase.
  hashedPassword String
  // Id du compte correspondant dans auth.users (Supabase). Nullable le temps
  // de la migration ; alimenté au signup et par le script de migration.
  authUserId     String?    @unique
  // Jeton secret du flux calendrier privé (iCal) — permet de s'abonner au
  // planning depuis Google/Apple Calendar via une URL non devinable. Null
  // tant que l'utilisateur n'a pas activé la synchronisation.
  icalToken      String?    @unique
  name           String
  role           UserRole   @default(EMPLOYEE)
  status         UserStatus @default(PENDING) // Workflow d'inscription
  isActive       Boolean    @default(true) // Désactivation post-approbation
  rejectionNote  String? // Motif optionnel en cas de refus
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  reviewedAt     DateTime? // Date de validation/refus
  reviewedById   String? // Admin ayant validé (référence libre)
  lastLoginAt    DateTime? // Mis à jour à chaque connexion réussie (audit)

  // Avatar fun : ID stable pointant vers /public/avatars/<id>.png
  // (paracetamol, ibuprofen, probiotic…). Null = fallback sur la pastille
  // colorée avec la 1re lettre du prénom. Voir src/lib/avatars.ts pour le
  // catalogue.
  avatarId String?

  // Reset password : on stocke le HASH SHA-256 du token (jamais le token brut).
  // Si la BDD fuite, les liens déjà émis ne sont pas exploitables.
  passwordResetTokenHash String?
  passwordResetExpires   DateTime?

  // Accès au module Rémunération (page /remuneration). Par défaut false ;
  // seul le super-admin (admin sans Employee lié, "compte créateur") peut
  // l'accorder à d'autres admins. Le super-admin a toujours accès implicite.
  // Les non-admins n'ont jamais accès, peu importe ce flag.
  canAccessPayroll Boolean @default(false)

  // Compte "Support PharmaPlanning" : visible comme contact dans toutes les
  // pharmacies. Permet aux utilisateurs de toute pharmacie d'écrire au
  // programmeur du site pour signaler un bug ou poser une question.
  // Le multi-tenant standard reste appliqué pour tous les autres comptes.
  isGlobalSupport Boolean @default(false)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  // Relation optionnelle 1:1 avec Employee
  // Un admin peut ne pas être un employé planifié
  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  // Messagerie interne
  conversationsCreated    Conversation[]       @relation("conversationsCreated")
  conversationMemberships ConversationMember[]
  messages                Message[]
  swapsRequested          ShiftSwapRequest[]   @relation("swapsRequested")
  swapsTargeted           ShiftSwapRequest[]   @relation("swapsTargeted")
  swapsReviewed           ShiftSwapRequest[]   @relation("swapsReviewed")
  payrollNotes            PayrollNote[]
  pushSubscriptions       PushSubscription[]

  @@index([pharmacyId])
  @@index([pharmacyId, status])
  @@map("users")
}

/// Abonnement Web Push d'un utilisateur (un par navigateur/appareil).
/// `endpoint` + clés issus de la PushSubscription du navigateur. Sert à
/// envoyer des notifications hors-app (absence validée, consigne, événement).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/// Employé — profil métier (apparaît comme colonne dans le planning)
/// Mode de rémunération d'un salarié.
enum PayMode {
  HOURLY // Payé au taux horaire : heures travaillées × taux
  MONTHLY // Mensualisé : salaire brut mensuel fixe (heures sup payées en plus)
}

/// Période de référence pour le décompte des heures supplémentaires.
enum OvertimeReference {
  WEEKLY // À la semaine (Art. L3121-28) — seuil = contrat/sem.
  BIWEEKLY // Lissé sur 2 semaines (modulation) — seuil = 2× contrat / quinzaine.
}

model Employee {
  id                      String            @id @default(cuid())
  firstName               String
  lastName                String
  status                  EmployeeStatus
  weeklyHours             Float // Heures contractuelles hebdomadaires
  // Période de référence pour le décompte des heures supplémentaires :
  //  - WEEKLY   : à la semaine (défaut) — seuil = weeklyHours/sem.
  //  - BIWEEKLY : lissé sur 2 semaines (modulation contractuelle) — seuil =
  //    2×weeklyHours sur la quinzaine (ex. 40h + 30h = 0 heure sup).
  overtimeReference       OvertimeReference @default(WEEKLY)
  // Pour les TITULAIRE uniquement : compter leurs heures supplémentaires dans
  // les stats ? Par défaut FALSE — un titulaire rémunéré en dividendes / salaire
  // fixe travaille « quoi qu'il arrive », ses HS ne sont donc pas
  // comptabilisées. Ignoré pour les autres statuts (leurs HS comptent toujours).
  titulaireCountsOvertime Boolean           @default(false)
  displayColor            String            @default("#6366f1") // Couleur dans le planning
  displayOrder            Int               @default(0) // Ordre d'affichage dans la grille
  isActive                Boolean           @default(true)
  hireDate                DateTime?

  // ─── Rémunération (module /remuneration) ───────────────────────────
  // Deux modes (payMode) :
  //  - HOURLY  : on utilise hourlyGrossRate (€/h brut).
  //  - MONTHLY : on utilise monthlyGrossSalary (€/mois brut, mensualisé).
  //    Taux horaire implicite = monthlyGrossSalary / heures mensuelles
  //    contractuelles (weeklyHours × 52/12). Les heures sup au-delà du
  //    contrat sont payées EN PLUS du salaire mensuel.
  // NB : ce n'est PAS un bulletin de paie légal (cf. avertissement page).
  payMode            PayMode @default(HOURLY)
  hourlyGrossRate    Float? // Taux horaire brut (mode HOURLY)
  monthlyGrossSalary Float? // Salaire brut mensuel (mode MONTHLY)
  // Coefficient conventionnel (grille pharmacie d'officine). Si renseigné,
  // sert de base au benchmark à la place de l'estimation par ancienneté.
  coefficient        Int?

  // ─── Échéances RH (rappels automatiques) ───────────────────────────
  contractType                  ContractType @default(CDI)
  contractEndDate               DateTime? // Fin de CDD / stage / apprentissage
  trialEndDate                  DateTime? // Fin de période d'essai (rappel seul)
  // Date de départ prévue (démission, rupture…). Au passage de cette date, OU
  // de contractEndDate pour un contrat non-CDI, le collaborateur bascule
  // automatiquement en inactif (cf. src/lib/employee-lifecycle.ts).
  departureDate                 DateTime?
  lastMedicalVisitDate          DateTime? // Dernière visite médicale du travail
  lastProfessionalInterviewDate DateTime? // Dernier entretien professionnel
  dpcLastDate                   DateTime? // Dernière action DPC (pharmacien)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  user                User?
  scheduleEntries     ScheduleEntry[]
  absenceRequests     AbsenceRequest[]
  templateEntries     WeekTemplateEntry[]
  availabilityWishes  AvailabilityWish[]
  gardes              Garde[]
  openShiftsAssigned  OpenShift[]          @relation("OpenShiftAssigned")
  openShiftVolunteers OpenShiftVolunteer[] @relation("OpenShiftVolunteer")
  pollVotes           PollVote[]           @relation("PollVote")
  trainings           Training[]

  @@index([pharmacyId])
  @@index([pharmacyId, isActive])
  @@map("employees")
}

/// Formation suivie par un collaborateur — catalogue + suivi DPC (rappel
/// triennal pour les pharmaciens). Chaque entrée = une formation datée,
/// rattachée à une officine et à un collaborateur.
model Training {
  id             String       @id @default(cuid())
  title          String // Intitulé de la formation
  type           TrainingType @default(EXTERNE)
  date           DateTime // Date de la formation (jour)
  provider       String? // Organisme / labo dispensateur
  notes          String? // Notes libres
  attestationUrl String? // Lien vers l'attestation (PDF hébergé ailleurs)
  createdAt      DateTime     @default(now())

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
  @@index([employeeId])
  @@map("trainings")
}

/// Type de contrat — sert aux rappels d'échéances (fin de CDD, etc.).
enum ContractType {
  CDI
  CDD
  APPRENTISSAGE
  STAGE
  INTERIM
}

/// Nature d'un souhait de disponibilité posé par un salarié.
enum WishKind {
  UNAVAILABLE // Indisponible (ne peut pas travailler)
  PREFER_OFF // Préfère ne pas travailler
  PREFER_WORK // Souhaite travailler
}

/// Souhait de disponibilité posé par un salarié pour un jour donné.
/// L'admin en tient compte (affichage) au moment de bâtir le planning.
model AvailabilityWish {
  id         String   @id @default(cuid())
  pharmacyId String
  employeeId String
  date       DateTime @db.Date
  kind       WishKind
  note       String?
  createdAt  DateTime @default(now())

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([pharmacyId, date])
  @@map("availability_wishes")
}

/// Chiffre d'affaires mensuel saisi par le titulaire — sert au ratio
/// masse salariale / CA sur la page Rémunération.
model MonthlyRevenue {
  id         String   @id @default(cuid())
  pharmacyId String
  month      String // "YYYY-MM"
  revenueHT  Float // CA HT du mois
  marginHT   Float? // Marge brute HT (optionnelle)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, month])
  @@map("monthly_revenues")
}

/// Entrée de planning — UNE cellule de la grille
/// Contrainte unique : un seul poste/absence par employé + date + créneau
model ScheduleEntry {
  id          String       @id @default(cuid())
  date        DateTime     @db.Date // Date du jour (sans heure)
  timeSlot    String // "HH:MM" — ex: "08:30", "14:00"
  type        ScheduleType // TASK ou ABSENCE
  taskCode    TaskCode? // Rempli si type = TASK
  absenceCode AbsenceCode? // Rempli si type = ABSENCE
  notes       String? // Note optionnelle sur le créneau

  // Sauvegarde du poste d'origine quand cette cellule a été convertie de
  // TASK → ABSENCE par l'approbation d'une demande d'absence. Permet de
  // restaurer le planning si l'admin annule l'absence après coup.
  // Null = la cellule n'a jamais été convertie (ou a été modifiée depuis).
  previousTaskCode TaskCode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  // Un seul enregistrement par employé + date + créneau
  @@unique([employeeId, date, timeSlot])
  // Index pour requêtes fréquentes
  @@index([pharmacyId, date])
  @@index([employeeId, date])
  @@map("schedule_entries")
}

/// Demande d'absence — workflow employé → admin
model AbsenceRequest {
  id          String               @id @default(cuid())
  dateStart   DateTime             @db.Date
  dateEnd     DateTime             @db.Date
  absenceCode AbsenceCode
  status      AbsenceRequestStatus @default(PENDING)
  reason      String? // Motif (optionnel pour l'employé)
  adminNote   String? // Note de l'admin (ex: raison refus)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  reviewedAt  DateTime? // Date de validation/refus

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, status])
  @@index([employeeId])
  // Perf : check de conflit d'absence exécuté à CHAQUE sauvegarde de planning
  // (pharmacyId + status + chevauchement dateStart/dateEnd) → range scan indexé
  // au lieu d'un filtre post-index sur les dates.
  @@index([pharmacyId, status, dateStart, dateEnd])
  // Perf : endpoint notifications employé (pollé) — filtre status + tri
  // reviewedAt desc servis par l'index au lieu d'un tri en mémoire.
  @@index([employeeId, status, reviewedAt])
  @@map("absence_requests")
}

/// Template de semaine type (S1 ou S2) — pour pré-remplissage rapide.
/// On peut désormais avoir PLUSIEURS gabarits par type (ex: "S1 standard",
/// "S1 vacances scolaires", "S2 été"...) — chacun avec son nom personnalisé.
model WeekTemplate {
  id          String   @id @default(cuid())
  name        String // Ex: "Semaine type S1 standard"
  weekType    WeekType // S1 ou S2
  category    String? // Classement libre selon les besoins (ex: "Vacances scolaires", "Renfort", "Été")
  description String? // Note libre décrivant l'usage du gabarit
  isDefault   Boolean  @default(false) // Gabarit "par défaut" pour son type (1 max par type/pharmacie) — pré-sélectionné à l'application
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  entries WeekTemplateEntry[]

  @@index([pharmacyId, weekType])
  @@map("week_templates")
}

/// Entrée d'un template de semaine — un créneau type
model WeekTemplateEntry {
  id          String       @id @default(cuid())
  dayOfWeek   Int // 0=Lundi, 1=Mardi, ..., 5=Samedi
  timeSlot    String // "HH:MM"
  type        ScheduleType
  taskCode    TaskCode?
  absenceCode AbsenceCode?

  templateId String
  template   WeekTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([templateId, employeeId, dayOfWeek, timeSlot])
  @@map("week_template_entries")
}

/// Événement de la vie de l'officine (repas d'équipe, animation labo, réunion
/// fournisseur, entretien…). Ajouté par les titulaires/manageurs, affiché à
/// droite de la page Équipe avec une ambiance visuelle par type.
model TeamEvent {
  id          String        @id @default(cuid())
  title       String
  description String?
  /// Date de l'événement (à minuit UTC). L'heure éventuelle est dans `time`.
  date        DateTime
  /// Heure optionnelle "HH:MM" (null = journée / horaire non précisé).
  time        String?
  type        TeamEventType @default(AUTRE)
  location    String? // Lieu optionnel (resto, salle, labo…)
  createdById String? // User ayant créé (référence libre, best-effort)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, date])
  @@map("team_events")
}

// ─── MESSAGERIE INTERNE ──────────────────────────────────────────

/// Conversation — 1-1 (membres=2) ou groupe (membres>2). Toujours scopé par pharmacie.
/// L'admin peut consulter toutes les conversations en lecture (modération harcèlement).
model Conversation {
  id        String   @id @default(cuid())
  name      String? // Null pour 1-1, défini pour groupe
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Bumpé à chaque message → tri par récence

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("conversationsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  members  ConversationMember[]
  messages Message[]

  @@index([pharmacyId, updatedAt])
  @@map("conversations")
}

/// Membre d'une conversation — table d'association User <-> Conversation
model ConversationMember {
  id         String    @id @default(cuid())
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime? // Pour calculer les unread

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

/// Message dans une conversation
model Message {
  id        String      @id @default(cuid())
  body      String // Texte du message (vide pour SWAP_REQUEST/SYSTEM)
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())

  // Pièce jointe optionnelle — image (PNG/JPG/WebP) stockée en base64
  // data URL. Limite 500KB max après compression côté client. Pour des
  // pièces lourdes (PDF, vidéo), on switchera vers Supabase Storage.
  attachmentUrl  String? @db.Text // data:image/jpeg;base64,...
  attachmentName String? // nom original (display only)
  attachmentMime String? // image/png, image/jpeg, image/webp

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Si type=SWAP_REQUEST, le message est associé à une demande d'échange
  swapRequestId String?           @unique
  swapRequest   ShiftSwapRequest? @relation(fields: [swapRequestId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// Demande d'échange de créneau — workflow demandeur → cible → admin
/// 1. Créée par le demandeur dans une conversation (status=PENDING_TARGET)
/// 2. La cible accepte (PENDING_ADMIN) ou refuse (REJECTED_TARGET)
/// 3. L'admin valide (APPROVED → planning maj) ou refuse (REJECTED_ADMIN)
model ShiftSwapRequest {
  id        String   @id @default(cuid())
  // Plage concernée
  date      DateTime @db.Date // Jour de l'échange
  startTime String? // "HH:MM" (null si journée entière)
  endTime   String? // "HH:MM" (null si journée entière)
  fullDay   Boolean  @default(false)
  reason    String? // Motif optionnel

  status        SwapStatus @default(PENDING_TARGET)
  acceptedAt    DateTime? // Quand la cible accepte
  reviewedAt    DateTime? // Quand l'admin tranche
  rejectionNote String? // Motif de refus (cible ou admin)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  // Demandeur (celui qui veut s'absenter)
  requesterId String
  requester   User   @relation("swapsRequested", fields: [requesterId], references: [id], onDelete: Cascade)

  // Cible (celui qui prendrait le créneau)
  targetId String
  target   User   @relation("swapsTargeted", fields: [targetId], references: [id], onDelete: Cascade)

  // Admin ayant tranché (optionnel)
  reviewedById String?
  reviewedBy   User?   @relation("swapsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  // Message d'origine dans la conversation (back-relation)
  message Message?

  @@index([pharmacyId, status])
  @@index([requesterId])
  @@index([targetId])
  @@map("shift_swap_requests")
}

/// Note de régularisation paie — équivalent de la colonne "Divers / Régul"
/// de l'Excel d'origine. N'importe quel collaborateur peut consigner un retard,
/// une absence à déduire, des heures sup à rattraper, etc. L'admin valide
/// (statut ACCOUNTED) et peut renseigner une `accountingNote` (ex: "OK déduit
/// sur 12/24"). Visible par toute l'équipe.
model PayrollNote {
  id             String   @id @default(cuid())
  /// Date de l'événement concerné (pas la date de saisie — la date à laquelle
  /// le retard / absence / heure sup s'est produit).
  date           DateTime @db.Date
  /// Texte principal saisi par l'auteur. Ex: "melanie 1h de retard".
  infos          String
  /// Motif optionnel. Ex: "problème garde son fils".
  motif          String?
  /// Note ajoutée par l'admin lors de la comptabilisation. Ex: "OK déduit
  /// sur 12/24". Null tant que la note n'est pas comptabilisée.
  accountingNote String?

  status        PayrollNoteStatus @default(PENDING)
  accountedAt   DateTime?
  accountedById String?

  // Pièce jointe optionnelle — image en base64 data URL (max 500KB après
  // compression). Sert à joindre une preuve : capture d'écran de SMS
  // d'absence, scan d'arrêt maladie, etc.
  attachmentUrl  String? @db.Text
  attachmentName String?
  attachmentMime String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
  @@index([pharmacyId, status])
  @@index([authorId])
  @@map("payroll_notes")
}

/// Compteur de rate-limit PARTAGÉ entre instances serverless (login, signup,
/// reset). Remplace le Map en mémoire (inefficace sur Vercel : 1 Map par
/// lambda). Une ligne par clé (ex: "login:email:x@y.fr" ou "signup:<ip>").
/// `resetAt` = fin de la fenêtre glissante ; nettoyé périodiquement (cron).
model RateLimitBucket {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
  @@map("rate_limit_buckets")
}

/// Type de garde (majoration principale). Aligné sur src/lib/gardes.ts.
enum GardeType {
  NUIT
  DIMANCHE
  JOUR_FERIE
}

/// Pharmacie de garde — un pharmacien assure une garde à une date donnée.
/// Sert au compteur d'équité, à la suggestion de rotation et au calcul des
/// indemnités (cf. src/lib/gardes.ts). Seuls les employés PHARMACIEN sont
/// affectables (contrôle applicatif).
model Garde {
  id               String      @id @default(cuid())
  date             DateTime    @db.Date
  type             GardeType
  // Majorations cumulées EN PLUS du type principal (ex. une NUIT un DIMANCHE).
  extraMajorations GardeType[]
  note             String?
  createdAt        DateTime    @default(now())

  pharmacistId String
  pharmacist   Employee @relation(fields: [pharmacistId], references: [id], onDelete: Cascade)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, date])
  @@index([pharmacistId])
  @@map("gardes")
}

// ─── Créneaux à couvrir ────────────────────────────────────────────
// Un responsable signale un trou de planning « à pourvoir » (date + plage
// horaire + poste optionnel). Les collaborateurs se positionnent (volunteers) ;
// le responsable en assigne un → statut FILLED (et peut écrire le planning).
enum OpenShiftStatus {
  OPEN // à pourvoir
  FILLED // pourvu (assigné à un collaborateur)
  CANCELLED // annulé
}

model OpenShift {
  id          String          @id @default(cuid())
  date        DateTime        @db.Date
  startSlot   String // "HH:MM" (inclus)
  endSlot     String // "HH:MM" (exclu)
  taskCode    TaskCode? // poste souhaité (optionnel)
  note        String?
  status      OpenShiftStatus @default(OPEN)
  createdById String? // User qui a créé le créneau (info)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  assignedEmployeeId String?
  assignedEmployee   Employee? @relation("OpenShiftAssigned", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  volunteers OpenShiftVolunteer[]

  @@index([pharmacyId, date])
  @@index([pharmacyId, status])
  @@map("open_shifts")
}

model OpenShiftVolunteer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  openShiftId String
  openShift   OpenShift @relation(fields: [openShiftId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation("OpenShiftVolunteer", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([openShiftId, employeeId])
  @@index([employeeId])
  @@map("open_shift_volunteers")
}

// ─── Sondage express ───────────────────────────────────────────────
// Un responsable pose une question à l'équipe (« Qui peut venir samedi ? »)
// avec des choix ; chacun répond en un tap. Résultats visibles par l'admin.
enum PollStatus {
  OPEN
  CLOSED
}

model Poll {
  id          String     @id @default(cuid())
  question    String
  options     String[] // choix possibles (one-tap), ex. ["Oui","Non","Peut-être"]
  status      PollStatus @default(OPEN)
  createdById String?
  createdAt   DateTime   @default(now())
  closesAt    DateTime?

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  votes PollVote[]

  @@index([pharmacyId, status])
  @@map("polls")
}

model PollVote {
  id        String   @id @default(cuid())
  choice    String
  createdAt DateTime @default(now())

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation("PollVote", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([pollId, employeeId])
  @@index([employeeId])
  @@map("poll_votes")
}
